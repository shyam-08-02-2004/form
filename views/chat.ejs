<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VIP Live Support Chat</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ── Global ── */
    * {margin:0;padding:0;box-sizing:border-box;}
    body {background:#0B0B0F;font-family:'Inter',sans-serif;color:#F8FAFC;min-height:100vh;display:flex;flex-direction:column;}
    a {color:inherit;text-decoration:none;}
    .hidden {display:none !important;}

    /* ── Navbar ── */
    .navbar {background:rgba(17,24,39,0.85);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.08);height:64px;padding:0 24px;display:flex;align-items:center;justify-content:space-between;}
    .brand {font-family:'Outfit',sans-serif;font-size:1.2rem;font-weight:700;color:#F4C542;}
    .nav-links a {margin-left:12px;font-size:0.9rem;color:rgba(255,255,255,0.6);transition:color 0.2s;}
    .nav-links a:hover,.nav-links a.active {color:#F4C542;}

    /* ── Chat Card ── */
    .chat-card {background:rgba(17,24,39,0.45);border:1px solid rgba(244,197,66,0.2);border-radius:20px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:0 8px 30px rgba(0,0,0,0.6);margin:20px auto;padding:20px;max-width:800px;width:100%;display:flex;flex-direction:column;}
    .chat-header {display:flex;align-items:center;gap:12px;margin-bottom:12px;}
    .agent-avatar {width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#34d399,#10b981);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#0B0B0F;position:relative;}
    .agent-avatar::after {content:"";width:12px;height:12px;background:#34d399;border:2px solid #0B0B0F;border-radius:50%;position:absolute;bottom:-4px;right:-4px;box-shadow:0 0 6px #34d399;}
    .chat-info {flex:1;}
    .chat-info h2 {font-size:1.1rem;color:#F8FAFC;margin:0;}
    .chat-info p {font-size:0.85rem;color:rgba(255,255,255,0.5);margin:4px 0 0;}
    .badges {display:flex;gap:8px;margin-top:6px;}
    .badge {display:flex;align-items:center;gap:4px;font-size:0.75rem;padding:4px 8px;border-radius:8px;background:rgba(255,255,255,0.08);color:#F8FAFC;}
    .badge.secure {color:#F4C542;}
    .badge.support24 {color:#94A3B8;}

    /* ── Messages ── */
    .messages {flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:14px;padding:10px;max-height:55vh;}
    .msg-row {display:flex;gap:10px;align-items:flex-start;}
    .msg-row.sent {flex-direction:row-reverse;}
    .msg-bubble {max-width:70%;padding:12px 16px;border-radius:16px;position:relative;font-size:0.9rem;line-height:1.5;word-break:break-word;cursor:pointer;transition:border-color 0.2s, box-shadow 0.2s;}
    .msg-row.received .msg-bubble {background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.08);color:#F8FAFC;}
    .msg-row.sent .msg-bubble {background:linear-gradient(135deg,rgba(244,197,66,0.15),rgba(244,197,66,0.05));border:1px solid rgba(244,197,66,0.2);color:#F8FAFC;}
    .msg-sender {font-weight:600;margin-bottom:4px;color:#F4C542;}
    .msg-time {font-size:0.75rem;color:rgba(255,255,255,0.4);margin-top:6px;text-align:right;}
    .msg-bubble.selected {border:2px solid #F4C542 !important;box-shadow:0 0 16px rgba(244,197,66,0.35);}
    .edited-badge {font-size:0.6rem;color:rgba(255,255,255,0.5);margin-left:6px;font-style:italic;}
    .msg-bubble img {max-width:100%;border-radius:8px;margin-top:6px;}

    /* ── Quick Replies ── */
    .quick-replies {display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;}
    .quick-btn {background:rgba(244,197,66,0.15);color:#F8FAFC;border:none;border-radius:12px;padding:6px 12px;font-size:0.85rem;cursor:pointer;transition:transform 0.2s,background 0.2s;}
    .quick-btn:hover {background:rgba(244,197,66,0.25);transform:scale(1.05);}

    /* ── Input Area ── */
    .input-area {background:rgba(255,255,255,0.05);border-top:1px solid rgba(255,255,255,0.08);border-radius:0 0 20px 20px;padding:12px 16px;display:flex;gap:8px;align-items:flex-end;}
    .chat-form {display:flex;gap:8px;align-items:flex-end;width:100%;}
    .textarea-wrap {flex:1;position:relative;}
    .textarea-wrap textarea {width:100%;min-height:44px;max-height:120px;resize:none;border:none;border-radius:12px;padding:10px 12px;background:rgba(255,255,255,0.06);color:#F8FAFC;font-family:'Inter',sans-serif;font-size:0.9rem;outline:none;transition:background 0.2s;}
    .textarea-wrap textarea:focus {background:rgba(255,255,255,0.1);border:1px solid rgba(244,197,66,0.4);}
    .icon-btn {width:38px;height:38px;border:none;border-radius:12px;background:rgba(255,255,255,0.06);color:#94A3B8;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background 0.2s;}
    .icon-btn:hover {background:rgba(255,255,255,0.12);}
    .send-btn {background:linear-gradient(135deg,#F4C542,#EAB308);color:#0B0B0F;border:none;border-radius:12px;width:48px;height:38px;font-size:1.2rem;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform 0.2s;}
    .send-btn:hover {transform:translateY(-2px);}

    /* ── Typing Indicator ── */
    .typing-indicator {display:flex;align-items:center;gap:4px;margin-left:8px;}
    .dot {width:6px;height:6px;background:#F4C542;border-radius:50%;animation:bounce 1.4s infinite;}
    .dot:nth-child(2){animation-delay:0.2s;}
    .dot:nth-child(3){animation-delay:0.4s;}
    @keyframes bounce {0%,80%,100%{opacity:0.3;transform:scale(0.8);}40%{opacity:1;transform:scale(1.2);}}

    /* ══════════════════════════════════════════
       MESSAGE ACTION POPUP — Premium Dark UI
       ══════════════════════════════════════════ */
    .action-overlay {
      position:fixed;top:0;left:0;width:100%;height:100%;
      background:rgba(0,0,0,0.5);
      z-index:1000;
      display:flex;align-items:flex-end;justify-content:center; /* Bottom sheet align */
      opacity:0;pointer-events:none;
      transition:opacity 0.25s ease;
    }
    .action-overlay.active {
      opacity:1;pointer-events:auto;
    }
    .action-sheet {
      background:#1a1d24; /* Dark theme to match image */
      border-radius:24px 24px 0 0; /* Rounded top corners */
      width:100%;max-width:100%;
      padding:12px 0 20px 0;
      box-shadow: 0 -10px 40px rgba(0,0,0,0.5);
      transform:translateY(100%);
      transition:transform 0.3s cubic-bezier(0.22,1,0.36,1);
    }
    .action-overlay.active .action-sheet {
      transform:translateY(0);
    }
    /* Action items */
    .action-item {
      display:flex;align-items:center;gap:20px;
      padding:16px 24px;
      cursor:pointer;
      transition:background 0.2s;
      border:none;background:none;width:100%;
      text-align:left;font-family:'Inter',sans-serif;
    }
    .action-item:hover {
      background:rgba(255,255,255,0.06);
    }
    .action-item:active {
      background:rgba(255,255,255,0.1);
    }
    .action-icon {
      display:flex;align-items:center;justify-content:center;
      color:#E2E8F0;
    }
    .action-label {
      font-size:1.1rem;font-weight:400;color:#E2E8F0;
    }
    .action-item.unsend .action-icon,
    .action-item.unsend .action-label {
      color:#EF4444;
    }
    /* Divider inside the sheet */
    .action-divider {
      height:1px;
      background:rgba(255,255,255,0.04);
      margin:0 24px;
    }

    /* ── Delete Confirm Modal ── */
    .vip-modal-overlay {
      position:fixed;top:0;left:0;width:100%;height:100%;
      background:rgba(0,0,0,0.8);
      backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
      z-index:2000;
      display:none;align-items:center;justify-content:center;
    }
    .vip-modal-overlay.active {display:flex;}
    .vip-modal {
      background:linear-gradient(180deg,#1a1f2e 0%,#111827 100%);
      border:1px solid rgba(255,255,255,0.1);
      border-radius:20px;
      padding:32px;max-width:360px;width:90%;text-align:center;
      animation:modalPop 0.3s ease;
    }
    @keyframes modalPop {
      from {transform:scale(0.85);opacity:0;}
      to {transform:scale(1);opacity:1;}
    }
    .vip-modal .warning-icon {font-size:2.5rem;margin-bottom:12px;}
    .vip-modal p {color:rgba(255,255,255,0.8);margin-bottom:20px;font-size:0.95rem;}
    .modal-actions {display:flex;gap:12px;justify-content:center;}
    .modal-actions .btn {
      padding:10px 24px;border:none;border-radius:12px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:transform 0.2s;
    }
    .modal-actions .btn:hover {transform:translateY(-2px);}
    .modal-actions .btn.cancel {background:rgba(255,255,255,0.08);color:#F8FAFC;}
    .modal-actions .btn.delete {background:linear-gradient(135deg,#EF4444,#DC2626);color:#fff;}

    /* ── Edit inline ── */
    .edit-input-wrap {display:flex;gap:8px;align-items:center;margin-top:8px;}
    .edit-input-wrap input {flex:1;background:rgba(255,255,255,0.08);border:1px solid rgba(244,197,66,0.3);border-radius:8px;padding:8px 12px;color:#F8FAFC;font-family:'Inter',sans-serif;font-size:0.85rem;outline:none;}
    .edit-input-wrap input:focus {border-color:#F4C542;}
    .edit-input-wrap button {background:linear-gradient(135deg,#F4C542,#EAB308);color:#0B0B0F;border:none;border-radius:8px;padding:8px 14px;font-weight:600;cursor:pointer;font-size:0.85rem;}

    /* ── Reply preview bar ── */
    .reply-preview {
      background:rgba(244,197,66,0.08);
      border-left:3px solid #F4C542;
      border-radius:0 8px 8px 0;
      padding:8px 12px;margin-bottom:8px;
      display:flex;align-items:center;justify-content:space-between;
      font-size:0.82rem;color:rgba(255,255,255,0.7);
    }
    .reply-preview .reply-text {flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .reply-preview .close-reply {background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;font-size:1.1rem;padding:0 4px;}
    /* Reply reference inside bubble */
    .reply-ref {
      background:rgba(244,197,66,0.08);
      border-left:3px solid #F4C542;
      border-radius:0 6px 6px 0;
      padding:4px 8px;margin-bottom:6px;
      font-size:0.78rem;color:rgba(255,255,255,0.5);
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    }

    /* ── Responsive ── */
    @media (max-width:640px){
      .navbar{height:56px;padding:0 12px;}
      .brand{font-size:1rem;}
      .chat-card{margin:8px;padding:12px;}
      .agent-avatar{width:40px;height:40px;font-size:1.2rem;}
      .msg-bubble{max-width:85%;font-size:0.85rem;}
      .action-item{padding:16px 24px;}
    }
    
    @media (min-width:641px){
      .action-overlay { align-items:center; }
      .action-sheet { max-width:340px; border-radius:16px; transform:scale(0.9); padding:8px 0; }
      .action-overlay.active .action-sheet { transform:scale(1); }
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="brand">💬 VIP Support</div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/profile">Profile</a>
      <a href="/refer-earn">Refer & Earn</a>
      <a href="/chat" class="active">Chat</a>
    </div>
  </nav>

  <div class="chat-card">
    <!-- Chat Header -->
    <div class="chat-header">
      <div class="agent-avatar">🧑‍💼</div>
      <div class="chat-info">
        <h2>Live Support Agent</h2>
        <p>Here to assist you 24/7 with any issues.</p>
        <div class="badges">
          <div class="badge secure">🔒 Secure Chat</div>
          <div class="badge support24">🎧 24/7 Support</div>
        </div>
      </div>
      <div style="width:12px;height:12px;background:#34d399;border-radius:50%;box-shadow:0 0 6px #34d399;" title="Agent Online"></div>
    </div>

    <!-- Messages -->
    <div class="messages" id="chatMessages">
      <% if (!messages || messages.length === 0) { %>
        <div style="text-align:center;color:rgba(255,255,255,0.4);">
          <p>No messages yet – start a conversation!</p>
        </div>
      <% } else { %>
        <% messages.forEach(function(msg, i){ %>
          <% var isSent = false; if (isAdmin && msg.sender==='admin') isSent=true; if (!isAdmin && msg.sender==='user') isSent=true; var canAct = isSent || isAdmin; %>
          <div class="msg-row <%= isSent ? 'sent' : 'received' %>" data-id="<%= msg.id %>">
            <div class="msg-avatar"><%= msg.sender==='admin' ? '🛡️' : '👤' %></div>
            <div class="msg-bubble" 
                 onclick="openActionSheet('<%= msg.id %>', <%= canAct %>, this)" 
                 oncontextmenu="event.preventDefault(); openActionSheet('<%= msg.id %>', <%= canAct %>, this)"
                 ontouchstart="startLongPress(event, '<%= msg.id %>', <%= canAct %>, this)"
                 ontouchend="cancelLongPress()"
                 ontouchmove="cancelLongPress()">
              <div class="msg-sender"><%= msg.sender==='admin' ? 'Support' : 'User' %></div>
              <div class="msg-content-wrapper" id="msg-content-<%= msg.id %>">
                <% if (msg.text) { %><p class="msg-text"><%= msg.text %></p><% } %>
                <% if (msg.image) { %><img src="<%= msg.image %>" alt="Attachment" /><% } %>
              </div>
              <div class="msg-time"><%= msg.time || '' %><% if (msg.isEdited) { %><span class="edited-badge">Edited</span><% } %></div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Quick Replies -->
    <div class="quick-replies">
      <button class="quick-btn" onclick="setQuickReply('Deposit Issue')">Deposit Issue</button>
      <button class="quick-btn" onclick="setQuickReply('Withdrawal Issue')">Withdrawal Issue</button>
      <button class="quick-btn" onclick="setQuickReply('Bonus Issue')">Bonus Issue</button>
      <button class="quick-btn" onclick="setQuickReply('Account Help')">Account Help</button>
    </div>

    <!-- Reply Preview Bar (shown when replying) -->
    <div class="reply-preview hidden" id="replyPreview">
      <span class="reply-text" id="replyPreviewText"></span>
      <button class="close-reply" onclick="cancelReply()">✕</button>
    </div>

    <!-- Input Area -->
    <div class="input-area">
      <form class="chat-form" action="/chat" method="POST" enctype="multipart/form-data" id="chatForm">
        <input type="hidden" name="replyTo" id="replyToInput" value="" />
        <label class="icon-btn" title="Attach image">📎<input type="file" name="image" accept="image/*" id="fileInput" style="display:none;" /></label>
        <label class="icon-btn" title="Emoji" onclick="openEmojiPicker()">😊</label>
        <div class="textarea-wrap"><textarea name="message" placeholder="Type your message..." rows="1" id="msgInput"></textarea></div>
        <button type="submit" class="send-btn" title="Send">➤</button>
      </form>
    </div>
  </div>

  <!-- ═══ ACTION SHEET OVERLAY ═══ -->
  <div class="action-overlay" id="actionOverlay" onclick="closeActionSheet(event)">
    <div class="action-sheet" id="actionSheet">

      <!-- Reply -->
      <button class="action-item" id="replyAction" onclick="doReply()">
        <div class="action-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h10a8 8 0 0 1 8 8v2M3 10l6 6m-6-6l6-6"/></svg>
        </div>
        <span class="action-label">Reply</span>
      </button>
      <div class="action-divider"></div>

      <!-- Edit -->
      <button class="action-item" id="editAction" onclick="doEdit()">
        <div class="action-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <span class="action-label">Edit</span>
      </button>
      <div class="action-divider"></div>

      <!-- Copy -->
      <button class="action-item" onclick="doCopy()">
        <div class="action-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        </div>
        <span class="action-label">Copy</span>
      </button>
      <div class="action-divider"></div>

      <!-- Unsend (Delete) -->
      <button class="action-item unsend" id="unsendAction" onclick="doUnsend()">
        <div class="action-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M16 12H8m0 0l4-4m-4 4l4 4"/></svg>
        </div>
        <span class="action-label">Unsend</span>
      </button>

    </div>
  </div>

  <!-- ═══ DELETE CONFIRM MODAL ═══ -->
  <div class="vip-modal-overlay" id="deleteModal">
    <div class="vip-modal">
      <div class="warning-icon">⚠️</div>
      <p>Are you sure you want to unsend this message?</p>
      <div class="modal-actions">
        <button class="btn cancel" onclick="closeDeleteModal()">Cancel</button>
        <button class="btn delete" id="confirmDeleteBtn">Unsend</button>
      </div>
    </div>
  </div>

  <script>
    /* ── State ── */
    let currentIsAdmin = <%= isAdmin ? 'true' : 'false' %>;
    let currentCanSend = <%= canSend ? 'true' : 'false' %>;
    let selectedMsgId = null;
    let selectedBubble = null;
    let selectedCanAct = false;
    let replyToId = null;
    
    // Store initial messages state to detect changes
    let lastMessagesHash = JSON.stringify(<%- JSON.stringify(messages || []) %>);

    /* ── Touch Long Press Handling (For iOS/Safari) ── */
    let longPressTimer;
    function startLongPress(e, msgId, canAct, element) {
      longPressTimer = setTimeout(() => {
        openActionSheet(msgId, canAct, element);
      }, 400); // 400ms long press
    }
    function cancelLongPress() {
      clearTimeout(longPressTimer);
    }

    /* ── Scroll to bottom ── */
    const chatBox = document.getElementById('chatMessages');
    if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;

    /* ── Textarea auto-resize ── */
    (function(){
      const ta = document.getElementById('msgInput');
      if (!ta) return;
      ta.addEventListener('input', function(){ this.style.height='44px'; this.style.height=Math.min(this.scrollHeight,120)+'px'; });
      ta.addEventListener('keydown', function(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();this.closest('form').submit();} });
    })();

    /* ── File input ── */
    (function(){
      const fi = document.getElementById('fileInput');
      if (fi) fi.addEventListener('change', function(){ /* optional file name display */ });
    })();

    /* ── Quick Reply ── */
    function setQuickReply(text){ document.getElementById('msgInput').value=text; document.getElementById('msgInput').focus(); }
    function openEmojiPicker(){ const ta=document.getElementById('msgInput'); ta.value+=' 😊'; ta.focus(); }

    /* ════════════════════════════
       ACTION SHEET – Open / Close
       ════════════════════════════ */
    function openActionSheet(msgId, canAct, bubbleEl) {
      selectedMsgId = msgId;
      selectedBubble = bubbleEl;
      selectedCanAct = canAct;

      // Highlight the selected bubble
      document.querySelectorAll('.msg-bubble.selected').forEach(b => b.classList.remove('selected'));
      bubbleEl.classList.add('selected');

      // Show/hide edit & unsend based on ownership
      document.getElementById('editAction').style.display = canAct ? 'flex' : 'none';
      document.getElementById('unsendAction').style.display = canAct ? 'flex' : 'none';

      // Show overlay
      document.getElementById('actionOverlay').classList.add('active');
    }

    function closeActionSheet(e) {
      if (e && e.target !== document.getElementById('actionOverlay')) return;
      document.getElementById('actionOverlay').classList.remove('active');
      if (selectedBubble) selectedBubble.classList.remove('selected');
      selectedMsgId = null;
      selectedBubble = null;
    }

    /* ── Reply ── */
    function doReply() {
      closeActionSheet({ target: document.getElementById('actionOverlay') });
      if (!selectedMsgId) return;
      // Get the message text
      const wrapper = document.getElementById('msg-content-' + selectedMsgId);
      const textEl = wrapper ? wrapper.querySelector('.msg-text') : null;
      const text = textEl ? textEl.textContent : '(image)';

      replyToId = selectedMsgId;
      document.getElementById('replyToInput').value = selectedMsgId;
      document.getElementById('replyPreviewText').textContent = '↩ ' + text.substring(0, 60);
      document.getElementById('replyPreview').classList.remove('hidden');
      document.getElementById('msgInput').focus();
    }

    function cancelReply() {
      replyToId = null;
      document.getElementById('replyToInput').value = '';
      document.getElementById('replyPreview').classList.add('hidden');
    }

    /* ── Copy ── */
    function doCopy() {
      if (!selectedMsgId) { closeActionSheet({ target: document.getElementById('actionOverlay') }); return; }
      const wrapper = document.getElementById('msg-content-' + selectedMsgId);
      const textEl = wrapper ? wrapper.querySelector('.msg-text') : null;
      const text = textEl ? textEl.textContent : '';
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          closeActionSheet({ target: document.getElementById('actionOverlay') });
        }).catch(() => {
          closeActionSheet({ target: document.getElementById('actionOverlay') });
        });
      } else {
        closeActionSheet({ target: document.getElementById('actionOverlay') });
      }
    }

    /* ── Edit ── */
    function doEdit() {
      const msgId = selectedMsgId;
      closeActionSheet({ target: document.getElementById('actionOverlay') });
      if (!msgId) return;

      const wrapper = document.getElementById('msg-content-' + msgId);
      if (!wrapper) return;
      const textEl = wrapper.querySelector('.msg-text');
      const currentText = textEl ? textEl.textContent : '';

      // Replace content with inline edit
      wrapper.innerHTML = `
        <div class="edit-input-wrap">
          <input type="text" id="editInput-${msgId}" value="${currentText.replace(/"/g,'&quot;')}" />
          <button onclick="submitEdit('${msgId}')">Save</button>
        </div>`;
      document.getElementById('editInput-' + msgId).focus();
    }

    function submitEdit(msgId) {
      const input = document.getElementById('editInput-' + msgId);
      if (!input) return;
      const newText = input.value.trim();
      if (!newText) return;

      fetch('/chat/edit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: msgId, newText: newText })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          const wrapper = document.getElementById('msg-content-' + msgId);
          wrapper.innerHTML = '<p class="msg-text">' + data.message.text + '</p>';
          // Add edited badge
          const row = document.querySelector(`[data-id="${msgId}"]`);
          if (row) {
            const timeEl = row.querySelector('.msg-time');
            if (timeEl && !timeEl.querySelector('.edited-badge')) {
              timeEl.innerHTML += '<span class="edited-badge">Edited</span>';
            }
          }
        }
      })
      .catch(err => console.error(err));
    }

    /* ── Unsend (Delete) ── */
    function doUnsend() {
      closeActionSheet({ target: document.getElementById('actionOverlay') });
      document.getElementById('deleteModal').classList.add('active');
      document.getElementById('confirmDeleteBtn').onclick = function() {
        if (!selectedMsgId) { closeDeleteModal(); return; }
        fetch('/chat/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: selectedMsgId })
        })
        .then(r => r.json())
        .then(data => {
          if (data.success) {
            const row = document.querySelector(`[data-id="${selectedMsgId}"]`);
            if (row) row.remove();
          }
          closeDeleteModal();
        })
        .catch(() => closeDeleteModal());
      };
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.remove('active');
    }

    /* ── Live Updates Render function ── */
    function renderMessages(messages, isAdmin) {
      const container = document.getElementById('chatMessages');
      if (!messages || messages.length === 0) {
        container.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.4);"><p>No messages yet – start a conversation!</p></div>';
        return;
      }
      
      let html = '';
      messages.forEach(msg => {
        let isSent = false;
        if (isAdmin && msg.sender === 'admin') isSent = true;
        if (!isAdmin && msg.sender === 'user') isSent = true;
        let canAct = isSent || isAdmin;
        
        let avatar = msg.sender === 'admin' ? '🛡️' : '👤';
        let senderName = msg.sender === 'admin' ? 'Support' : 'User';
        let editedBadge = msg.isEdited ? '<span class="edited-badge">Edited</span>' : '';
        
        let contentHtml = '';
        if (msg.text) contentHtml += '<p class="msg-text">' + msg.text.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</p>';
        if (msg.image) contentHtml += '<img src="' + msg.image + '" alt="Attachment" />';
        
        html += `
          <div class="msg-row ${isSent ? 'sent' : 'received'}" data-id="${msg.id}">
            <div class="msg-avatar">${avatar}</div>
            <div class="msg-bubble" 
                 onclick="openActionSheet('${msg.id}', ${canAct}, this)" 
                 oncontextmenu="event.preventDefault(); openActionSheet('${msg.id}', ${canAct}, this)"
                 ontouchstart="startLongPress(event, '${msg.id}', ${canAct}, this)"
                 ontouchend="cancelLongPress()"
                 ontouchmove="cancelLongPress()">
              <div class="msg-sender">${senderName}</div>
              <div class="msg-content-wrapper" id="msg-content-${msg.id}">
                ${contentHtml}
              </div>
              <div class="msg-time">${msg.time || ''}${editedBadge}</div>
            </div>
          </div>
        `;
      });
      
      // Save scroll position
      const isScrolledToBottom = container.scrollHeight - container.clientHeight <= container.scrollTop + 50;
      
      container.innerHTML = html;
      
      if (isScrolledToBottom) {
        container.scrollTop = container.scrollHeight;
      }
    }

    /* ── Auto-refresh polling ── */
    setInterval(function(){
      // Do not auto-refresh if a menu is open or user is currently typing an edit
      if (document.getElementById('actionOverlay').classList.contains('active')) return;
      if (document.querySelector('.edit-input-wrap')) return;

      fetch('/chat/messages')
      .then(r=>r.json())
      .then(data=>{
        currentCanSend = data.canSend;
        
        const newHash = JSON.stringify(data.messages);
        if (lastMessagesHash !== newHash) {
          lastMessagesHash = newHash;
          renderMessages(data.messages, data.isAdmin);
        }
      })
      .catch(()=>{});
    }, 2000);
  </script>
</body>
</html>
