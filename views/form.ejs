<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Form</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Navbar ── */
        .navbar {
            background: rgba(15, 12, 41, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 0 24px;
            height: 64px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .navbar .brand {
            font-size: 1.15rem;
            font-weight: 700;
            background: linear-gradient(135deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.3px;
        }
        .navbar .nav-links { display: flex; gap: 6px; }
        .navbar .nav-links a {
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 10px;
            transition: all 0.25s ease;
        }
        .navbar .nav-links a:hover,
        .navbar .nav-links a.active {
            color: #fff;
            background: rgba(167, 139, 250, 0.15);
        }

        /* ── Form Container ── */
        .form-wrapper {
            flex: 1;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 30px 16px;
        }
        .form-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 32px 28px;
            width: 100%;
            max-width: 520px;
        }
        .form-card h1 {
            color: #fff;
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 24px;
            text-align: center;
            background: linear-gradient(135deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-card input {
            width: 100%;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 12px 16px;
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.88rem;
            outline: none;
            transition: all 0.25s ease;
            margin-bottom: 14px;
        }
        .form-card input::placeholder { color: rgba(255,255,255,0.35); }
        .form-card input:focus {
            border-color: rgba(167,139,250,0.4);
            box-shadow: 0 0 0 3px rgba(167,139,250,0.1);
            background: rgba(255,255,255,0.08);
        }

        .form-card button {
            width: 100%;
            padding: 13px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #a78bfa, #7c3aed);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            margin-top: 6px;
        }
        .form-card button:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 24px rgba(167,139,250,0.35);
        }
        .form-card button:active { transform: scale(0.98); }

        /* ── Responsive ── */
        @media (max-width: 640px) {
            .navbar { padding: 0 10px; height: 56px; }
            .navbar .brand { font-size: 1rem; }
            .navbar .nav-links { gap: 2px; }
            .navbar .nav-links a { padding: 5px 8px; font-size: 0.72rem; }
            .form-wrapper { padding: 20px 10px; }
            .form-card { padding: 24px 18px; }
            .form-card h1 { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar">
    <div class="brand">📋 Admin Panel</div>
    <div class="nav-links">
        <a href="/form" class="active">Dashboard</a>
        <a href="/profile">Profile</a>
        <a href="/refer-earn">Refer & Earn</a>
        <a href="/chat">💬 Chat</a>
    </div>
</nav>

<!-- Form -->
<div class="form-wrapper">
    <div class="form-card">
        <h1>Student Form</h1>
        <form action="/submit" method="POST">
            <input type="text" name="name" placeholder="Name" required>
            <input type="number" name="age" placeholder="Age" required>
            <input type="text" name="studyYear" placeholder="Study Year" required>
            <input type="text" name="education" placeholder="Education" required>
            <input type="text" name="parentName" placeholder="Parent Name" required>
            <input type="text" name="mobile" placeholder="Mobile Number" required>
            <input type="text" name="whatsapp" placeholder="Whatsapp Number" required>
            <button type="submit">Submit</button>
        </form>
    </div>
</div>

</body>
</html>