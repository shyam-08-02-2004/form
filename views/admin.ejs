<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🂡 Dragon Tiger – Admin Panel</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* Simple layout for the admin dashboard */
    .dashboard {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2rem;
    }
    .section {
      width: 100%;
      max-width: 1000px;
      margin-bottom: 2rem;
    }
    .section h2 {
      color: var(--color-text);
      margin-bottom: 1rem;
    }
    .iframe-wrapper {
      background: rgba(17,24,39,0.45);
      border: 1px solid rgba(244,197,66,0.2);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 8px 30px rgba(0,0,0,0.6);
    }
    .iframe-wrapper iframe {
      width: 100%;
      height: 600px;
      border: none;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="brand">🂡 Dragon Tiger Admin</div>
    <div class="nav-links">
      <a href="/admin" class="active">Dashboard</a>
      <a href="/form">Student Form</a>
      <a href="/profile">Profile</a>
      <a href="/refer-earn">Refer & Earn</a>
      <a href="/chat">Support Chat</a>
    </div>
  </nav>
  <div class="dashboard">
    <div class="main-content">
      <section class="section">
        <h2>Game Administration</h2>
        <p style="color: var(--color-secondary);">Here you can manage the Dragon Tiger game settings, monitor bets, and view analytics. (Implementation placeholder)</p>
      </section>
      <section class="section">
        <h2>Live Premium Support</h2>
        <div class="iframe-wrapper">
          <iframe src="/chat" title="Live Support Chat"></iframe>
        </div>
      </section>
    </div>
  </div>
</body>
</html>
